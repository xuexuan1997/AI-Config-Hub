{
  "name": "@ai-config-hub/desktop",
  "version": "0.2.11",
  "private": true,
  "type": "module",
  "main": "dist/main/main/main.js",
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build:main": "pnpm --filter @ai-config-hub/shared build && pnpm --filter @ai-config-hub/core build && pnpm --filter @ai-config-hub/adapters build && pnpm --filter @ai-config-hub/api build && pnpm --filter @ai-config-hub/deployer build && pnpm --filter @ai-config-hub/git build && pnpm --filter @ai-config-hub/scanner build && pnpm --filter @ai-config-hub/storage build && tsc -p tsconfig.build.json",
    "build:renderer": "vite build --config vite.config.ts",
    "build": "pnpm run build:main && pnpm run build:renderer",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "vitest run --root ../.. apps/desktop/src",
    "test:e2e": "playwright test --config ../../playwright.config.ts --project desktop",
    "package": "pnpm run build",
    "package:linux": "pnpm run package:linux:x64",
    "package:linux:x64": "pnpm run build && electron-builder --linux AppImage --x64 --config.directories.output=../../release/linux-x64",
    "package:windows:x64": "pnpm run build && electron-builder --win nsis --x64 --config.directories.output=../../release/windows-x64",
    "package:macos:x64": "pnpm run build && electron-builder --mac dmg --x64 --config.directories.output=../../release/macos-x64",
    "package:macos:arm64": "pnpm run build && electron-builder --mac dmg --arm64 --config.directories.output=../../release/macos-arm64"
  },
  "dependencies": {
    "@ai-config-hub/adapters": "workspace:*",
    "@ai-config-hub/api": "workspace:*",
    "@ai-config-hub/core": "workspace:*",
    "@ai-config-hub/deployer": "workspace:*",
    "@ai-config-hub/git": "workspace:*",
    "@ai-config-hub/scanner": "workspace:*",
    "@ai-config-hub/shared": "workspace:*",
    "@ai-config-hub/storage": "workspace:*",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "electron": "42.4.1",
    "electron-builder": "26.15.3",
    "tslib": "2.8.1",
    "vite": "8.0.16"
  }
}
