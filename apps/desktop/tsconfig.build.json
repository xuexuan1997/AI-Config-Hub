{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "incremental": true,
    "outDir": "dist/main",
    "paths": {},
    "rootDir": "src",
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.build.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.cts"],
  "exclude": ["src/**/*.test.ts", "src/renderer/**"]
}
