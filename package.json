{
  "name": "ai-config-hub",
  "version": "0.2.10",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --if-present dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "tsc -p tsconfig.json --noEmit && pnpm -r --if-present typecheck",
    "lint": "eslint . && prettier --check . && depcruise --config dependency-cruiser.mjs apps packages",
    "test": "vitest run --coverage --maxWorkers=1 && pnpm test:contracts",
    "test:contracts": "node --test tests/tooling/*.test.mjs tests/packaging/*.test.mjs",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "package:linux": "pnpm package:linux:x64",
    "package:linux:x64": "pnpm --filter @ai-config-hub/desktop package:linux:x64",
    "package:windows:x64": "pnpm --filter @ai-config-hub/desktop package:windows:x64",
    "package:macos:x64": "pnpm --filter @ai-config-hub/desktop package:macos:x64",
    "package:macos:arm64": "pnpm --filter @ai-config-hub/desktop package:macos:arm64",
    "release:sbom": "node scripts/release/generate-sbom.mjs",
    "release:evidence": "node scripts/release/generate-manifest.mjs",
    "release:verify": "node scripts/release/verify-artifacts.mjs",
    "package": "pnpm --filter @ai-config-hub/desktop package && pnpm --filter @ai-config-hub/cli package"
  },
  "devDependencies": {
    "@ai-config-hub/api": "workspace:*",
    "@ai-config-hub/core": "workspace:*",
    "@ai-config-hub/shared": "workspace:*",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.0",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.9",
    "dependency-cruiser": "17.4.3",
    "eslint": "10.5.0",
    "prettier": "3.8.4",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  }
}
